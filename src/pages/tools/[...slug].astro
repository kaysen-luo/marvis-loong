---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import ArticleLayout from '@/layouts/ArticleLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('tools', ({ data }) => !data.draft)
  const sorted = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }))
}

interface Props {
  entry: CollectionEntry<'tools'>
  prev: CollectionEntry<'tools'> | null
  next: CollectionEntry<'tools'> | null
}

const { entry, prev, next } = Astro.props
const { Content } = await render(entry)
const ext = entry.filePath?.split('.').pop() ?? 'md'
---

<ArticleLayout
  section="tools"
  title={entry.data.title}
  date={entry.data.date}
  tags={entry.data.tags}
  description={entry.data.description}
  rawText={entry.body}
  slug={entry.id}
  fileExt={ext}
  prev={prev ? { href: `/tools/${prev.id}`, title: prev.data.title } : null}
  next={next ? { href: `/tools/${next.id}`, title: next.data.title } : null}
>
  <Content />
</ArticleLayout>
