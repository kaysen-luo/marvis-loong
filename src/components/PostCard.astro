---
import { formatDate } from '@/utils'

interface Props {
  href: string
  title: string
  date: Date
  description?: string | undefined
  tags?: string[]
}

const { href, title, date, description, tags = [] } = Astro.props
---

<a href={href} class="post-card">
  <div class="post-card-main">
    <h3 class="post-card-title">{title}</h3>
    {description && <p class="post-card-desc">{description}</p>}
    <div class="post-card-meta">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {
        tags.length > 0 && (
          <>
            <span class="dot" />
            <div class="post-card-tags">
              {tags.map((t) => (
                <span class="chip">{t}</span>
              ))}
            </div>
          </>
        )
      }
    </div>
  </div>
  <span class="arrow">→</span>
</a>

<style>
  .post-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 22px 24px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all var(--transition);
    color: var(--text-primary);
  }
  .post-card:hover {
    background: var(--bg-hover);
    border-color: var(--border-hover);
    transform: translateX(2px);
  }
  .post-card-main {
    flex: 1;
    min-width: 0;
  }
  .post-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .post-card-desc {
    color: var(--text-secondary);
    font-size: 14px;
    margin-bottom: 10px;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .post-card-meta time {
    font-family: var(--font-mono);
  }
  .post-card-meta .dot {
    width: 3px;
    height: 3px;
    background: var(--text-muted);
    border-radius: 50%;
  }
  .post-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .arrow {
    color: var(--text-muted);
    font-size: 18px;
    transition: all var(--transition);
  }
  .post-card:hover .arrow {
    color: var(--accent);
    transform: translateX(3px);
  }
</style>
